{
  "name": "figma-forge",
  "private": true,
  "description": "Claude Code ↔ Figma 双向操控平台（基于 Plugin API + MCP）",
  "scripts": {
    "dev:plugin": "cd packages/plugin && pnpm build",
    "dev:bridge": "cd packages/bridge && pnpm dev",
    "build": "pnpm -r build",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "clean": "pnpm -r clean",
    "publish:shared": "cd packages/shared && pnpm publish --no-git-checks",
    "publish:bridge": "cd packages/bridge && pnpm publish --no-git-checks",
    "publish:all": "pnpm publish:shared && pnpm publish:bridge"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
